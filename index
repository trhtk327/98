<!DOCTYPE html>
<html lang="he" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>צ'אט הארי פוטר</title>

<style>
*{box-sizing:border-box;margin:0;padding:0}

html,body{
  height:100%;
  overflow:hidden;
  font-family:Arial;
  background:#3f5f73;
}

.app{
  width:95%;
  max-width:500px;
  height:calc(100vh - 115px);
  margin:10px auto;
  background:#e4f1f9;
  display:flex;
  flex-direction:column;
  border-radius:18px;
  border:3px solid #4da6ff;
  overflow:hidden;
}

.header{
  padding:12px;
  text-align:center;
  background:#6ec1ff;
  color:#fff;
}

#chat{
  flex:1;
  overflow-y:auto;
  padding:10px;
  display:flex;
  flex-direction:column;
  background:#d9ecf7;
}

.msg{
  max-width:75%;
  padding:10px;
  margin:5px 0;
  border-radius:14px;
}

.me{background:#6ec1ff;align-self:flex-end}
.other{background:#9cc7e4;align-self:flex-start}

.nameRow{
  display:flex;
  justify-content:space-between;
}

.dots{cursor:pointer}

.replyBox{
  background:rgba(255,255,255,0.6);
  padding:5px;
  border-radius:8px;
  margin-bottom:5px;
  font-size:12px;
}

.time{font-size:10px}

.input{
  display:flex;
  padding:10px;
  background:#cfe8f7;
}
.input input{flex:1;padding:10px;border-radius:20px;border:none}
.input button{padding:10px;border:none;background:#4da6ff;color:#fff;border-radius:20px}

.modal{
  position:fixed;
  inset:0;
  background:rgba(0,0,0,0.6);
  display:flex;
  justify-content:center;
  align-items:center;
}

.box{
  background:#fff;
  padding:20px;
  border-radius:12px;
  width:90%;
  max-width:300px;
}

#menu{
  position:fixed;
  background:#fff;
  padding:10px;
  border-radius:10px;
  display:none;
  z-index:999;
}

.reactions{
  display:flex;
  gap:5px;
  margin-top:5px;
}
.reaction{
  background:rgba(0,0,0,0.1);
  padding:2px 6px;
  border-radius:10px;
  font-size:11px;
}
</style>
</head>

<body>

<div class="app">
<div class="header">💬 צ'אט הארי פוטר</div>

<div id="chat"></div>

<div class="input">
  <input id="msg">
  <button onclick="sendMessage()">שלח</button>
</div>
</div>

<div class="modal" id="nameModal">
  <div class="box">
    <input id="nameInput" placeholder="שם">
    <input id="phoneInput" placeholder="טלפון חובה">
    <input id="aboutInput" placeholder="עליי">
    <button onclick="saveUser()">אישור</button>
  </div>
</div>

<div class="modal" id="infoModal" style="display:none">
  <div class="box" id="infoText"></div>
</div>

<div id="menu"></div>

<script type="module">
import { initializeApp } from "https://www.gstatic.com/firebasejs/12.11.0/firebase-app.js";
import { getDatabase, ref, push, onChildAdded, onValue, remove, set, get } from "https://www.gstatic.com/firebasejs/12.11.0/firebase-database.js";

const app = initializeApp({
  apiKey:"AIzaSyC1YgGDcl-mv9R7w3ysSrKx8kPf_QuWzEs",
  databaseURL:"https://harry-potter-chat-default-rtdb.europe-west1.firebasedatabase.app"
});
const db = getDatabase(app);

let user = JSON.parse(localStorage.getItem("user"));
let selectedKey;
let replyData=null;

if(!user) nameModal.style.display="flex";

window.saveUser=()=>{
  const name=nameInput.value.trim();
  const phone=phoneInput.value.trim();
  const about=aboutInput.value.trim();

  if(!name || !phone) return alert("חובה");

  user={name,phone,about};
  localStorage.setItem("user",JSON.stringify(user));
  nameModal.style.display="none";
};

window.sendMessage=()=>{
  const text=msg.value;
  if(!text)return;

  push(ref(db,"messages"),{
    ...user,
    text,
    time:new Date().toLocaleTimeString(),
    fullTime:new Date().toISOString(),
    reply:replyData,
    edited:false
  });

  msg.value="";
  replyData=null;
};

onChildAdded(ref(db,"messages"),snap=>{
  const m=snap.val();
  const key=snap.key;

  const div=document.createElement("div");
  div.className="msg "+(m.name===user.name?"me":"other");

  div.innerHTML=`
  <div class="nameRow">
    <span>${m.name}</span>
    <span class="dots" onclick="openMenu(event,'${key}')">⋮</span>
  </div>

  ${m.reply ? `<div class="replyBox">${m.reply.name}: ${m.reply.text}</div>`:""}

  <div id="text-${key}">
    ${m.text}
    <div class="time">${m.time}${m.edited?" (ערוך)":""}</div>
  </div>

  <div class="reactions" id="react-${key}"></div>
  `;

  chat.appendChild(div);
});

window.openMenu=(e,key)=>{
  selectedKey=key;

  menu.innerHTML=`
  <div onclick="details()">📄 פרטים</div>
  <div onclick="reply()">💬 להגיב</div>
  <div onclick="edit()">✏️ עריכה</div>
  <div onclick="del()">❌ מחק</div>
  `;

  menu.style.display="block";
};

window.details=async()=>{
  const m=(await get(ref(db,"messages/"+selectedKey))).val();
  infoText.innerHTML=`${m.text}<br>${m.name}<br>${m.phone}`;
  infoModal.style.display="flex";
};

window.del=()=> remove(ref(db,"messages/"+selectedKey));

window.edit=async()=>{
  const el=document.getElementById("text-"+selectedKey);
  const m=(await get(ref(db,"messages/"+selectedKey))).val();

  el.innerHTML=`
  <input id="editInput" value="${m.text}">
  <button onclick="saveEdit('${selectedKey}')">✔</button>
  `;
};

window.saveEdit=(k)=>{
  set(ref(db,"messages/"+k+"/text"),editInput.value);
  set(ref(db,"messages/"+k+"/edited"),true);
};

window.reply=async()=>{
  const m=(await get(ref(db,"messages/"+selectedKey))).val();
  replyData={name:m.name,text:m.text};
};

onValue(ref(db,"reactions"),snap=>{
  snap.forEach(m=>{
    let map={};
    m.forEach(u=>{
      map[u.val()]=(map[u.val()]||0)+1;
    });

    let html="";
    for(let e in map){
      html+=`<span class="reaction">${e} ${map[e]}</span>`;
    }

    const el=document.getElementById("react-"+m.key);
    if(el) el.innerHTML=html;
  });
});
</script>

</body>
</html>
